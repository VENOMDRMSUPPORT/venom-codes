# Environment Variables
# Copy this file to .env and fill in your values

# Node Environment
NODE_ENV=development

# Server Port
PORT=8080

# JWT Configuration
JWT_SECRET=your-secret-key-here-min-16-chars
JWT_EXPIRES_IN=7d

# WHMCS API Configuration
WHMCS_URL=https://your-whmcs-domain.com
WHMCS_IDENTIFIER=your-whmcs-api-identifier
WHMCS_SECRET=your-whmcs-api-secret

# Frontend Origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Database Configuration (NEW - Required for database access)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-database-password
DB_NAME=whmcs

# Optional: Admin API Key (enables /api/admin routes)
VENOM_ADMIN_API_KEY=your-admin-api-key-min-8-chars

# Optional: Webhook Secret (for WHMCS webhooks)
VENOM_WEBHOOK_SECRET=your-webhook-secret-min-16-chars

# Optional: Enable SSL API
VENOM_ENABLE_SSL_API=false

# Logging
LOG_LEVEL=info
