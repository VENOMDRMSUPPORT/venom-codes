# API base URL for the browser (same-origin in production behind reverse proxy)
# Leave empty when the SPA is served from the same host as /api
VITE_API_BASE_URL=

# Local dev with Vite proxy: often leave empty and proxy /api to backend
# Example absolute API: https://api.example.com

# Optional when running behind HTTPS reverse proxy (nginx/caddy/traefik)
VITE_HMR_HOST=dev.venom-codes.test
VITE_HMR_CLIENT_PORT=443
